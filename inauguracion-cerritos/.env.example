# Copia este archivo a .env y complétalo. NUNCA subir .env al repo.

# --- Base de datos (Postgres del compose) ---
POSTGRES_USER=cerritos
POSTGRES_PASSWORD=pon-una-clave-fuerte
POSTGRES_DB=cerritos

# --- URLs / dominio ---
PUBLIC_BASE_URL=https://cerritos.ferreinox.co
FRONTEND_URL=https://cerritos.ferreinox.co
CORS_ORIGINS=https://cerritos.ferreinox.co,http://localhost:3000
# "" para mismo dominio (rutas relativas /api). En local: http://localhost:8000
NEXT_PUBLIC_API_URL=

# --- Seguridad ---
JWT_SECRET=genera-un-secreto-largo-aleatorio

# --- Admin (primer usuario, se crea al arrancar) ---
ADMIN_EMAIL=admin@ferreinox.co
ADMIN_PASSWORD=pon-una-clave-de-admin

# --- SendGrid ---
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=tiendapintucopereira@ferreinox.co
SENDGRID_FROM_NAME=Ferreinox S.A.S. BIC

# --- SMTP (respaldo Gmail, opcional) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tiendapintucopereira@ferreinox.co
SMTP_PASSWORD=app-password-de-gmail

# --- Tienda ---
STORE_WHATSAPP=573102806605
